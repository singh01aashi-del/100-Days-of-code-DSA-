#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

#define MAXN 1000
#define MAXE 10000

// --------- Graph ----------
typedef struct Node {
    int v, w;
    struct Node* next;
} Node;

Node* adj[MAXN];

// --------- Min Heap ----------
typedef struct {
    int v;
    int dist;
} HeapNode;

HeapNode heap[MAXE];
int heapSize = 0;

// Swap
void swap(HeapNode* a, HeapNode* b) {
    HeapNode t = *a;
    *a = *b;
    *b = t;
}

// Heapify up
void push(int v, int dist) {
    heap[heapSize].v = v;
    heap[heapSize].dist = dist;
    
    int i = heapSize++;
    
    while (i > 0) {
        int p = (i - 1) / 2;
        if (heap[p].dist <= heap[i].dist) break;
        swap(&heap[p], &heap[i]);
        i = p;
    }
}

// Heapify down
HeapNode pop() {
    HeapNode root = heap[0];
    heap[0] = heap[--heapSize];
    
    int i = 0;
    while (1) {
        int l = 2*i + 1, r = 2*i + 2, smallest = i;
        
        if (l < heapSize && heap[l].dist < heap[smallest].dist)
            smallest = l;
        if (r < heapSize && heap[r].dist < heap[smallest].dist)
            smallest = r;
        
        if (smallest == i) break;
        
        swap(&heap[i], &heap[smallest]);
        i = smallest;
    }
    
    return root;
}

// Add edge
void addEdge(int u, int v, int w) {
    Node* node = (Node*)malloc(sizeof(Node));
    node->v = v;
    node->w = w;
    node->next = adj[u];
    adj[u] = node;
}

// Dijkstra
void dijkstra(int n, int src, int dist[]) {
    for (int i = 0; i < n; i++) {
        dist[i] = INT_MAX;
    }
    
    dist[src] = 0;
    push(src, 0);
    
    while (heapSize > 0) {
        HeapNode cur = pop();
        int u = cur.v;
        
        if (cur.dist > dist[u]) continue;
        
        Node* temp = adj[u];
        while (temp) {
            int v = temp->v;
            int w = temp->w;
            
            if (dist[u] + w < dist[v]) {
                dist[v] = dist[u] + w;
                push(v, dist[v]);
            }
            
            temp = temp->next;
        }
    }
}

// --------- Example Usage ----------
int main() {
    int n = 5;
    
    addEdge(0, 1, 2);
    addEdge(0, 2, 4);
    addEdge(1, 2, 1);
    addEdge(1, 3, 7);
    addEdge(2, 4, 3);
    addEdge(3, 4, 1);
    
    int dist[MAXN];
    
    dijkstra(n, 0, dist);
    
    for (int i = 0; i < n; i++) {
        printf("Distance from 0 to %d = %d\n", i, dist[i]);
    }
    
    return 0;
}
