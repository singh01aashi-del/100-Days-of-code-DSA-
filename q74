#include <stdio.h>
#include <string.h>

#define MAX_VOTES 1000
#define MAX_NAME 100

typedef struct {
    char name[MAX_NAME];
    int count;
} Candidate;

int main() {
    int n;
    scanf("%d", &n);

    Candidate arr[MAX_VOTES];
    int size = 0;

    char name[MAX_NAME];

    for (int i = 0; i < n; i++) {
        scanf("%s", name);

        int found = 0;

        // check if candidate already exists
        for (int j = 0; j < size; j++) {
            if (strcmp(arr[j].name, name) == 0) {
                arr[j].count++;
                found = 1;
                break;
            }
        }

        // new candidate
        if (!found) {
            strcpy(arr[size].name, name);
            arr[size].count = 1;
            size++;
        }
    }

    // find winner
    char winner[MAX_NAME];
    int maxVotes = 0;

    for (int i = 0; i < size; i++) {
        if (arr[i].count > maxVotes) {
            maxVotes = arr[i].count;
            strcpy(winner, arr[i].name);
        } 
        else if (arr[i].count == maxVotes) {
            if (strcmp(arr[i].name, winner) < 0) {
                strcpy(winner, arr[i].name);
            }
        }
    }

    printf("%s %d\n", winner, maxVotes);

    return 0;
}
