//Problem: Rotate Linked List Right by k Places - Implement using linked list with dynamic memory allocation.

#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node *next;
};

int main() {
    int n, k, i;
    struct node *head = NULL, *temp = NULL, *newnode, *tail;

    scanf("%d", &n);

    // Create linked list
    for(i = 0; i < n; i++) {
        newnode = (struct node*)malloc(sizeof(struct node));
        scanf("%d", &newnode->data);
        newnode->next = NULL;

        if(head == NULL) {
            head = newnode;
            temp = newnode;
        } else {
            temp->next = newnode;
            temp = newnode;
        }
    }

    scanf("%d", &k);

    if(n == 0) return 0;

    k = k % n;   // handle k > n

    if(k == 0) {
        temp = head;
        while(temp != NULL) {
            printf("%d ", temp->data);
            temp = temp->next;
        }
        return 0;
    }

    // Find tail
    tail = head;
    while(tail->next != NULL)
        tail = tail->next;

    // Make circular list
    tail->next = head;

    // Find new tail (n-k-1)
    temp = head;
    for(i = 0; i < n-k-1; i++)
        temp = temp->next;

    // New head
    head = temp->next;
    temp->next = NULL;

    // Print rotated list
    temp = head;
    while(temp != NULL) {
        printf("%d ", temp->data);
        temp = temp->next;
    }

    return 0;
}
